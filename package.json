  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "dev": "vite",
    "build": "vite build",
    "db:generate": "bun run drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun run drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "bun run drizzle-kit push --config drizzle.config.ts",
    "db:studio": "bun run drizzle-kit studio --config drizzle.config.ts",
    "db:studio:local": "bun run drizzle-kit studio --config drizzle.config.local.ts",
    "db:dev": "bunx wrangler dev",
    "deploy": "vite build && bunx wrangler deploy"
  },
